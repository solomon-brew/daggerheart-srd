{
  "SectionHeaderProcessor": {
    "level_count": 4,
    "default_level": 2,
    "merge_threshold": 0.2,
    "height_tolerance": 0.98
  },
  "LLMSectionHeaderProcessor": {
    "use_llm": true,
    "max_concurrency": 1
  },
  "LLMPageCorrectionProcessor": {
    "use_llm": true,
    "max_concurrency": 1,
    "block_correction_prompt": "Use visual hierarchy for headings. The largest bold or all-caps header is H1. A smaller bold or all-caps header that directly follows it is H2. Do not assign the same level to stacked headers unless they are visually the same size."
  },
  "LLMTableProcessor": {
    "use_llm": true,
    "max_rows_per_batch": 40,
    "max_table_iterations": 2
  },
  "TextProcessor": {
    "column_gap_ratio": 0.03
  },
  "StructureBuilder": {
    "gap_threshold": 0.05,
    "list_gap_threshold": 0.1
  },
  "MarkdownRenderer": {
    "paginate_output": true,
    "html_tables_in_markdown": false,
    "extract_images": true
  }
}
